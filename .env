#
# AI Copilot Service (Ponti-AI) - Example env
#
# Objetivo:
# - Que puedas correr `make run` (API local) apuntando a una DB accesible
# - Sin incluir secretos reales
#
# Nota:
# - En `docker-compose.yml` muchas vars se inyectan directo por service.
# - Este archivo es para correr la API fuera de Docker o como referencia.
#

# === App ===
APP_NAME=ai-copilot-service
APP_ENV=local

# === DB ===
# Para docker compose local (si expones ai-db en 55432)
DB_DSN=postgresql://postgres:postgres@localhost:55432/ai_copilot?sslmode=disable

# === Security ===
# Lista CSV de service keys validas (ej: "k1,k2")
AI_SERVICE_KEYS=servicekey123

# === SQL Safety/Limits ===
STATEMENT_TIMEOUT_MS=20000
MAX_LIMIT=200
DEFAULT_LIMIT=50

# === RAG ===
EMBEDDING_DIM=1536
RAG_TOP_K=5

# Embeddings provider (para RAG). Opciones: stub|ollama|openai|google_ai_studio
# Recomendado local con Docker: ollama + nomic-embed-text
EMBEDDING_PROVIDER=stub
EMBEDDING_MODEL=nomic-embed-text

# === LLM ===
# Opciones: stub|ollama|openai|google_ai_studio
LLM_PROVIDER=stub
LLM_MODEL=stub
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434
LLM_TIMEOUT_S=20
LLM_MAX_RETRIES=3

# === Insights (reglas) ===
INSIGHTS_RATIO_HIGH=0.5
INSIGHTS_RATIO_MEDIUM=0.2
INSIGHTS_SPIKE_RATIO=1.5
INSIGHTS_COOLDOWN_DAYS=7
INSIGHTS_IMPACT_K=1.0
INSIGHTS_IMPACT_CAP=2.0

# === Baselines/Jobs ===
INSIGHTS_SIZE_SMALL_MAX=200
INSIGHTS_SIZE_MEDIUM_MAX=1000
INSIGHTS_PROJECT_BASELINE_DAYS=365
INSIGHTS_MIN_SAMPLES_PROJECT=10
INSIGHTS_BASELINE_LOCK_KEY=41001
INSIGHTS_RECOMPUTE_LOCK_KEY=41002
INSIGHTS_BASELINE_BATCH_SIZE=200

# === Planner (LLM) ===
DOMAIN=agriculture
MAX_ACTIONS_ALLOWED=4

# === ML (Isolation Forest) ===
ML_ENABLED=false
ML_MODEL_TYPE=isolation_forest
ML_MODELS_DIR=ml_models

# Hiperparametros IF (training)
ML_IF_CONTAMINATION=0.05
ML_IF_N_ESTIMATORS=100
ML_IF_RANDOM_STATE=42

# Thresholds (inference)
ML_ANOMALY_THRESHOLD=0.6
ML_SEVERITY_HIGH=0.8
ML_SEVERITY_MEDIUM=0.5
ML_COOLDOWN_DAYS=7

# Ops de ML
ML_RETRAIN_LOCK_KEY=41003
ML_ROLLOUT_PERCENT=100
ML_ENABLED_PROJECT_IDS=
ML_SHADOW_MODE=false

# Promotion/Auto-retrain policy
ML_AUTO_PROMOTE=true
ML_AUTO_RETRAIN_MIN_HOURS=24
ML_PROMOTION_MIN_ALERT_RATE_IMPROVEMENT=0.01
ML_PROMOTION_MIN_SAMPLES_RATIO=0.8
