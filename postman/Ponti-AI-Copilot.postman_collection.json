{
  "info": {
    "name": "Ponti AI Copilot",
    "description": "Colección de endpoints del AI Copilot Service (ponti-ai)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8090"
    },
    {
      "key": "service_key",
      "value": "servicekey123"
    },
    {
      "key": "user_id",
      "value": "123"
    },
    {
      "key": "project_id",
      "value": "demo-project"
    },
    {
      "key": "insight_id",
      "value": "7e1bdc3e-6ec0-5814-9d7d-50c1d3486612"
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Healthz",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/healthz",
            "description": "Health check básico"
          }
        },
        {
          "name": "Readyz",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/readyz",
            "description": "Readiness check (incluye verificación de DB)"
          }
        },
        {
          "name": "Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/metrics",
            "description": "Métricas del servicio"
          }
        }
      ]
    },
    {
      "name": "Copilot",
      "item": [
        {
          "name": "Explain Insight",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "{{user_id}}"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "url": "{{base_url}}/v1/copilot/insights/{{insight_id}}/explain",
            "description": "Explicación del insight"
          }
        },
        {
          "name": "Why Insight",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "{{user_id}}"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "url": "{{base_url}}/v1/copilot/insights/{{insight_id}}/why",
            "description": "Por qué ocurrió el insight"
          }
        },
        {
          "name": "Next Steps",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "{{user_id}}"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "url": "{{base_url}}/v1/copilot/insights/{{insight_id}}/next-steps",
            "description": "Próximos pasos sugeridos para el insight"
          }
        },
        {
          "name": "RAG Ingest",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "{{user_id}}"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documents\": [\n    {\n      \"source\": \"manual\",\n      \"title\": \"Guia\",\n      \"content\": \"Contenido de prueba\"\n    }\n  ]\n}"
            },
            "url": "{{base_url}}/v1/rag/ingest",
            "description": "Ingesta de documentos al RAG"
          }
        }
      ]
    },
    {
      "name": "Insights",
      "item": [
        {
          "name": "Compute Insights",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "{{user_id}}"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{base_url}}/v1/insights/compute",
            "description": "Computar insights para el proyecto"
          }
        },
        {
          "name": "Get Insights by Entity",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "{{user_id}}"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/insights/:entity_type/:entity_id",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "insights",
                ":entity_type",
                ":entity_id"
              ],
              "variable": [
                {
                  "key": "entity_type",
                  "value": "project"
                },
                {
                  "key": "entity_id",
                  "value": "demo-project"
                }
              ]
            },
            "description": "Obtener insights por tipo de entidad e ID"
          }
        },
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "{{user_id}}"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "url": "{{base_url}}/v1/insights/summary",
            "description": "Resumen: new_count_total, new_count_high_severity, top 3 insights"
          }
        },
        {
          "name": "Record Action",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "{{user_id}}"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"acknowledged\",\n  \"new_status\": \"acknowledged\"\n}"
            },
            "url": "{{base_url}}/v1/insights/{{insight_id}}/actions",
            "description": "Registrar acción sobre un insight"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Recompute Active",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "scheduler"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batch_size\": 100\n}"
            },
            "url": "{{base_url}}/v1/jobs/recompute-active",
            "description": "Recomputar insights activos (ej. Cloud Scheduler)"
          }
        },
        {
          "name": "Recompute Baselines",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-SERVICE-KEY",
                "value": "{{service_key}}"
              },
              {
                "key": "X-USER-ID",
                "value": "scheduler"
              },
              {
                "key": "X-PROJECT-ID",
                "value": "{{project_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batch_size\": 200\n}"
            },
            "url": "{{base_url}}/v1/jobs/recompute-baselines",
            "description": "Recomputar baselines de cohorte y proyecto"
          }
        }
      ]
    }
  ]
}
