# Ponti AI — Environment Variables
#
# Copiar este archivo como `.env` y ajustar valores.
# Para docker compose, las vars se inyectan directo por service.
#
# La app usa pydantic-settings con env_ignore_empty=True:
#   - Variables vacías (ej: LLM_API_KEY=) se tratan como no seteadas y usan el default.
#   - Variables requeridas sin valor fallan al arranque con error claro.

# === App ===
APP_NAME=ponti-ai
APP_ENV=local

# === DB ===
# Para docker-compose (recomendado): usar el hostname del service `ai-db`.
DB_DSN=postgresql://postgres:postgres@ai-db:5432/ponti_ai?sslmode=disable

# === Security ===
# Lista CSV de service keys validas (ej: "k1,k2")
AI_SERVICE_KEYS=local-dev-ai-service-key

# === SQL Safety/Limits ===
STATEMENT_TIMEOUT_MS=20000
MAX_LIMIT=200
DEFAULT_LIMIT=50

# === Copilot (LLM) ===
COPILOT_ENABLED=true
# Asistente conversacional (/v1/chat). Usa el mismo LLM_PROVIDER; stub usa respuesta local sin red.
CHAT_ENABLED=true
# Por defecto usar stub (no requiere API key ni servicio extra).
LLM_PROVIDER=stub
# Opciones: stub | ollama | openai | google_ai_studio | google
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=http://ollama:11434
LLM_TIMEOUT_MS=5000
LLM_MAX_RETRIES=3
LLM_MAX_OUTPUT_TOKENS=700
LLM_MAX_CALLS_PER_REQUEST=3
LLM_BUDGET_TOKENS_PER_REQUEST=2500
LLM_RATE_LIMIT_RPS=2.0

# === Insights (reglas determinísticas) ===
INSIGHTS_RATIO_HIGH=0.5
INSIGHTS_RATIO_MEDIUM=0.2
INSIGHTS_SPIKE_RATIO=1.5
INSIGHTS_COOLDOWN_DAYS=7
INSIGHTS_IMPACT_K=1.0
INSIGHTS_IMPACT_CAP=2.0
INSIGHTS_SIZE_SMALL_MAX=200
INSIGHTS_SIZE_MEDIUM_MAX=1000

# === Domain ===
DOMAIN=agriculture
MAX_ACTIONS_ALLOWED=4

# === Chat: lecturas ponti-backend vía tools (opcional) ===
# URL base del API manager (sin barra final), ej. http://ponti-backend:8080
PONTI_BACKEND_BASE_URL=
PONTI_BACKEND_API_KEY=
PONTI_BACKEND_TIMEOUT_MS=15000
PONTI_BACKEND_MAX_RESPONSE_CHARS=16000
# Opcional si el backend exige Authorization además de X-API-KEY
PONTI_BACKEND_AUTHORIZATION=
CHAT_MAX_TOOL_CALLS=14
CHAT_PROJECT_CONTEXT_TTL_SECONDS=900
CHAT_DASHBOARD_CONTEXT_TTL_SECONDS=600
