APP_NAME=ai-copilot-service
APP_ENV=local
DB_DSN=postgresql://postgres:postgres@localhost:55432/ai_copilot?sslmode=disable
AI_SERVICE_KEYS=servicekey123
STATEMENT_TIMEOUT_MS=2000
MAX_LIMIT=200
DEFAULT_LIMIT=50
EMBEDDING_DIM=1536
RAG_TOP_K=5
# Valores soportados: stub | openai | google_ai_studio | ollama
LLM_PROVIDER=ollama
# OpenAI: gpt-4o-mini | Google: gemini-flash-latest | Ollama: llama3.1 (ejemplo)
LLM_MODEL=llama3.1
# LLM_API_KEY solo es requerido si LLM_PROVIDER in (openai, google_ai_studio)
LLM_API_KEY=
# LLM_BASE_URL opcional (por defecto, OpenAI public API). Permite apuntar a un proxy interno.
# Para Ollama local: http://localhost:11434
# Para Ollama en docker-compose: http://ollama:11434
LLM_BASE_URL=
LLM_TIMEOUT_S=20
LLM_MAX_RETRIES=3
INSIGHTS_RATIO_HIGH=0.5
INSIGHTS_RATIO_MEDIUM=0.2
INSIGHTS_SPIKE_RATIO=1.5
INSIGHTS_COOLDOWN_DAYS=7
INSIGHTS_IMPACT_K=1.0
INSIGHTS_IMPACT_CAP=2.0
INSIGHTS_SIZE_SMALL_MAX=200
INSIGHTS_SIZE_MEDIUM_MAX=1000
INSIGHTS_PROJECT_BASELINE_DAYS=365
INSIGHTS_MIN_SAMPLES_PROJECT=10
INSIGHTS_BASELINE_LOCK_KEY=41001
INSIGHTS_RECOMPUTE_LOCK_KEY=41002
INSIGHTS_BASELINE_BATCH_SIZE=200

# Planner v2
DOMAIN=agriculture
MAX_ACTIONS_ALLOWED=4
